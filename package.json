{
  "name": "travel_planner",
  "version": "1.0.0",
  "description": "JourneyAI travel planning application",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "node src/app.js",
    "install-all": "npm install && cd ai_backend && pip install -r requirements.txt",
    "start-ai": "cd ai_backend && .venv\\Scripts\\python.exe -X utf8 -m uvicorn backend.main:app --host 0.0.0.0 --port 8000",
    "build:css": "node scripts/build-css.js",
    "check": "npm run build:css && npm run check:js && npm run check:python",
    "check:js": "node scripts/check-js.js",
    "check:python": "python -m compileall -q ai_backend/backend",
    "test": "npm run check"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "connect-mongo": "^5.1.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-session": "^1.18.0",
    "mongoose": "^9.2.3",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17"
  }
}
